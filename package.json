{
  "name": "bibby-frontend",
  "private": true,
  "version": "0.0.0",
  "description": "Frontend tooling (Tailwind + Playwright) for Bibby.",
  "scripts": {
    "css:build": "tailwindcss -i ./public/styles/tailwind.css -o ./public/styles.css --minify",
    "css:watch": "tailwindcss -i ./public/styles/tailwind.css -o ./public/styles.css --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^22.10.0",
    "tailwindcss": "^4.0.0",
    "wait-on": "^8.0.1"
  }
}
